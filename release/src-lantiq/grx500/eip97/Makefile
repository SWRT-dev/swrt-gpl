# Convert swrt build environment variable to sdk
include ../sdk.config
include ../rules.mk
PKG_BUILD_DIR=$(shell pwd)/source

PKG_EXTRA_KCONFIG += \
	CONFIG_CRYPTO_DEV_LANTIQ_EIP97=m \
	CONFIG_LTQ_CRYPTO=y \
	CONFIG_LTQ_MPE_IPSEC_SUPPORT=y

PKG_EXTRA_CFLAGS += \
	-DCONFIG_LTQ_CRYPTO \
	-DCONFIG_CRYPTO_DEV_LANTIQ_EIP97 \
	-DCONFIG_LTQ_MPE_IPSEC_SUPPORT \
	-DCONFIG_LTQ_CRYPTO_MAX_RING_USED=2 \
	-DCONFIG_PPA_MPE_IP97
EXTRA_CFLAGS+=$(PKG_EXTRA_CFLAGS)

INSTALLKMODDIR:=$(INSTALLDIR)/lib/modules/$(LINUX_KERNEL)


all:
	$(KERNEL_MAKE) $(PARALLEL_BUILD) $(PKG_EXTRA_KCONFIG) EXTRA_CFLAGS="$(EXTRA_CFLAGS)" M="$(PKG_BUILD_DIR)" modules
	touch stamp-h1

install:
	@[ -d $(INSTALLKMODDIR) ] || install -d $(INSTALLKMODDIR)
	@install -D $(PKG_BUILD_DIR)/ltq_crypto.ko $(INSTALLKMODDIR)
	@$(STRIPX) $(INSTALLKMODDIR)/*.ko

clean:

stage:


