CONFIG_UBOOT_CONFIG_BCH_CONT_T=7
CONFIG_UBOOT_CONFIG_SPL_OOBSIZE=64
# CONFIG_UBOOT_CONFIG_NAND_BBT_SCAN is not set
# CONFIG_UBOOT_CONFIG_NAND_FLASH_8192M is not set
# CONFIG_UBOOT_CONFIG_NAND_FLASH_4096M is not set
# CONFIG_UBOOT_CONFIG_NAND_FLASH_2048M is not set
# CONFIG_UBOOT_CONFIG_NAND_FLASH_1024M is not set
# CONFIG_UBOOT_CONFIG_NAND_FLASH_512M is not set
# CONFIG_UBOOT_CONFIG_NAND_FLASH_256M is not set
CONFIG_UBOOT_CONFIG_NAND_FLASH_128M=y
# CONFIG_UBOOT_CONFIG_NAND_FLASH_64M is not set
# CONFIG_UBOOT_CONFIG_NAND_FLASH_32M is not set
# CONFIG_UBOOT_CONFIG_NAND_FLASH_8M is not set
# CONFIG_UBOOT_CONFIG_NAND_FLASH_4M is not set
# CONFIG_UBOOT_CONFIG_NAND_FLASH_2M is not set
CONFIG_UBOOT_CONFIG_NAND_FLASH_SIZE=128
CONFIG_UBOOT_CONFIG_NAND_PAGE_SIZE=0x800
CONFIG_UBOOT_CONFIG_NAND_BLOCK_SIZE=0x20000
CONFIG_UBOOT_CONFIG_NAND_SPL_BLOCK_SIZE=0xA000
# CONFIG_UBOOT_CONFIG_NAND_PRELOAD is not set
# CONFIG_UBOOT_CONFIG_NAND_SPL_BBT is not set
CONFIG_UBOOT_CONFIG_FIRMWARE_IN_ROOTFS=y
# CONFIG_UBOOT_CONFIG_LTQ_I2C is not set
CONFIG_UBOOT_CONFIG_DRIVER_GRX500=y
# CONFIG_UBOOT_CONFIG_GRX500_A11 is not set
CONFIG_UBOOT_CONFIG_GRX500_A21=y
CONFIG_UBOOT_CONFIG_BOARD_EASY350=y
# CONFIG_UBOOT_CONFIG_BOARD_EVM is not set
CONFIG_UBOOT_CONFIG_GRX500_ROM_HEADER_BCH_CAP=8
# CONFIG_UBOOT_CONFIG_GRX500_BOOT_4KEC_ONLY is not set
# CONFIG_UBOOT_CONFIG_GRX500_THERMAL is not set

#
# Memory configuration for Trusted OS
#
# CONFIG_UBOOT_CONFIG_TOS_16M is not set
CONFIG_UBOOT_CONFIG_TOS_32M=y
# CONFIG_UBOOT_CONFIG_TOS_64M is not set
# CONFIG_UBOOT_CONFIG_TOS_128M is not set
# CONFIG_UBOOT_CONFIG_DDR_256M is not set
CONFIG_UBOOT_CONFIG_DDR_512M=y
# CONFIG_UBOOT_CONFIG_DDR_1G is not set
CONFIG_UBOOT_CONFIG_FMT1_REG=0xFE003E00

#
# MIPS and DDR Settings
#
# CONFIG_UBOOT_CONFIG_GRX500_USE_DDR_PRECONFIG is not set
# CONFIG_UBOOT_CONFIG_GRX500_DDR2 is not set
CONFIG_UBOOT_CONFIG_GRX500_DDR3=y
# CONFIG_UBOOT_CONFIG_GRX500_400M_CL6 is not set
# CONFIG_UBOOT_CONFIG_GRX500_533M_CL6 is not set
# CONFIG_UBOOT_CONFIG_GRX500_533M_CL7 is not set
# CONFIG_UBOOT_CONFIG_GRX500_533M_CL8 is not set
# CONFIG_UBOOT_CONFIG_GRX500_667M_CL8 is not set
CONFIG_UBOOT_CONFIG_GRX500_667M_CL9=y
# CONFIG_UBOOT_CONFIG_GRX500_667M_CL10 is not set
# CONFIG_UBOOT_CONFIG_GRX500_800M_CL9 is not set
# CONFIG_UBOOT_CONFIG_GRX500_800M_CL10 is not set
# CONFIG_UBOOT_CONFIG_GRX500_800M_CL11 is not set
# CONFIG_UBOOT_CONFIG_GRX500_32Mx16 is not set
# CONFIG_UBOOT_CONFIG_GRX500_64Mx8 is not set
# CONFIG_UBOOT_CONFIG_GRX500_64Mx16 is not set
# CONFIG_UBOOT_CONFIG_GRX500_128Mx8 is not set
# CONFIG_UBOOT_CONFIG_GRX500_128Mx16 is not set
# CONFIG_UBOOT_CONFIG_GRX500_256Mx8 is not set
CONFIG_UBOOT_CONFIG_GRX500_256Mx16=y
# CONFIG_UBOOT_CONFIG_GRX500_512Mx8 is not set
# CONFIG_UBOOT_CONFIG_GRX500_512Mx16 is not set
CONFIG_UBOOT_CONFIG_GRX500_BL8=y
# CONFIG_UBOOT_CONFIG_GRX500_BC4 is not set

#
# DDR Pre-Seed Rank 0 Value
#
CONFIG_UBOOT_CONFIG_GRX500_1ST_SR0_VALUE=24
CONFIG_UBOOT_CONFIG_GRX500_2ND_SR0_VALUE=24

#
# DDR Pre-Seed Rank 1 Value
#
CONFIG_UBOOT_CONFIG_GRX500_1ST_SR1_VALUE=24
CONFIG_UBOOT_CONFIG_GRX500_2ND_SR1_VALUE=24
# CONFIG_UBOOT_CONFIG_GRX500_DDR_CTRL_200M is not set
CONFIG_UBOOT_CONFIG_GRX500_DDR_CTRL_333M=y
# CONFIG_UBOOT_CONFIG_GRX500_DDR_CTRL_400M is not set
CONFIG_UBOOT_CONFIG_GRX500_CS0_ONLY=y
CONFIG_UBOOT_CONFIG_GRX500_ADDITIVE_LATENCY=1

#
# End of DDR configurations 
#
# CONFIG_UBOOT_CONFIG_GRX500_CPU_600M is not set
CONFIG_UBOOT_CONFIG_GRX500_CPU_800M=y
# CONFIG_UBOOT_CONFIG_GRX500_CPU_1000M is not set
# CONFIG_UBOOT_CONFIG_GRX500_CPU_1200M is not set
# CONFIG_UBOOT_CONFIG_GRX500_CBM_FREQ_200M is not set
# CONFIG_UBOOT_CONFIG_GRX500_CBM_FREQ_300M is not set
# CONFIG_UBOOT_CONFIG_GRX500_CBM_FREQ_400M is not set
# CONFIG_UBOOT_CONFIG_GRX500_CBM_FREQ_480M is not set
CONFIG_UBOOT_CONFIG_GRX500_CBM_FREQ_600M=y
# CONFIG_UBOOT_CONFIG_GRX500_CBM_FREQ_800M is not set
# CONFIG_UBOOT_CONFIG_GRX500_CBM_FREQ_1200M is not set
# CONFIG_UBOOT_CONFIG_GRX500_CBM_FREQ_2400M is not set
CONFIG_UBOOT_CONFIG_GRX500_MIPS_ENDIAN_BE=y

#
# SWITCH OPTIONS
#
CONFIG_UBOOT_CONFIG_NETWORK_VIA_LAN=y
# CONFIG_UBOOT_CONFIG_NETWORK_VIA_WAN is not set
CONFIG_UBOOT_CONFIG_GRX500_PHY2=y
CONFIG_UBOOT_CONFIG_GRX500_PHY3=y
CONFIG_UBOOT_CONFIG_GRX500_PHY4=y
CONFIG_UBOOT_CONFIG_GRX500_PHY5=y
CONFIG_UBOOT_CONFIG_GRX500_GPHY_FW_EMBEDDED=y
CONFIG_UBOOT_CONFIG_GRX500_GPHY_FW_ADDR=0xa0230000

#
# Environment Settings
#
CONFIG_UBOOT_CONFIG_ENV_SIZE=0x4000
CONFIG_UBOOT_CONFIG_ENV_REDUND=y
CONFIG_UBOOT_CONFIG_ENV_OVERWRITE=y
CONFIG_UBOOT_CONFIG_BUILD_ENV_BLOCK=y
CONFIG_UBOOT_CONFIG_TFTP_LOAD_ADDRESS="0x80800000"
CONFIG_UBOOT_CONFIG_MEM="224M"
CONFIG_UBOOT_CONFIG_PHYM="224M"
CONFIG_UBOOT_CONFIG_BOOTDELAY=5
CONFIG_UBOOT_CONFIG_ROOT_PATH="/mnt/full_fs"
CONFIG_UBOOT_CONFIG_CONSOLE="ttyLTQ0"
CONFIG_UBOOT_CONFIG_TFTPPATH=""
CONFIG_UBOOT_CONFIG_ROOTFSMTD="/dev/mtdblock6"
CONFIG_UBOOT_CONFIG_NFSARGS="setenv bootargs ubi.mtd=system_sw root=/dev/nfs rw nfsroot=${serverip}:${rootpath}"
CONFIG_UBOOT_CONFIG_RAMARGS="setenv bootargs root=/dev/ram rw"
CONFIG_UBOOT_CONFIG_FLASHARGS="setenv bootargs ubi.mtd=system_sw ubi.block=0,${rootfsname} root=254:0 ro rootfstype=squashfs"
CONFIG_UBOOT_CONFIG_ADDIP="setenv bootargs ${bootargs} ip=${ipaddr}:${serverip}:${gatewayip}:${netmask}:${hostname}:${netdev}:on"
CONFIG_UBOOT_CONFIG_ADDMISC="setenv bootargs ${bootargs} console=${console},${baudrate} ethaddr=${ethaddr} panic=1 ${mtdparts} init=/etc/preinit active_bank=${active_bank} update_chk=${update_chk} maxcpus=4 pci=pcie_bus_perf ethwan=${ethwan} ubootver=${ver} mem=224M@512M"
CONFIG_UBOOT_CONFIG_BLVER="0.0.3.12"
CONFIG_UBOOT_CONFIG_BOOTFILE="uImage"
CONFIG_UBOOT_CONFIG_BOOT_CORE="openwrt-intel_mips-xrx500_4kec-easy350550_bootcore-initramfs-kernel.bin"
CONFIG_UBOOT_CONFIG_U_BOOT="u-boot.ltq"
CONFIG_UBOOT_CONFIG_ROOTFS="rootfs.img"
CONFIG_UBOOT_CONFIG_FIRMWARE="firmware.img"
CONFIG_UBOOT_CONFIG_FULLIMAGE="fullimage.img"
CONFIG_UBOOT_CONFIG_TOTALIMAGE="totalimage.img"
CONFIG_UBOOT_CONFIG_MTDIDS="nand0=17c00000.nand-parts"
# CONFIG_UBOOT_CONFIG_USE_DEFAULT_MTDPARTS is not set
CONFIG_UBOOT_CONFIG_MTDPARTS="mtdparts=17c00000.nand-parts:1m(uboot),256k(ubootconfigA),256k(ubootconfigB),256k(gphyfirmware),1m(calibration),16m(bootcore),256k(pro_info),256k(dev_info),108m(system_sw),-(res)"
CONFIG_UBOOT_CONFIG_FLASH_NFS="run nfsargs addip addmisc;bootm ${kernel_addr}"
CONFIG_UBOOT_CONFIG_NET_RAM="run run_bootcore;tftp ${loadaddr} ${tftppath}${bootfile}; run ramargs addip addmisc; bootm"
CONFIG_UBOOT_CONFIG_NET_FLASH="run run_bootcore;tftp ${loadaddr} ${tftppath}${bootfile}; run flashargs addip addmisc; bootm"
CONFIG_UBOOT_CONFIG_NET_NFS="run run_bootcore;tftp ${loadaddr} ${tftppath}${bootfile};run nfsargs addip addmisc;bootm"
CONFIG_UBOOT_CONFIG_FLASH_FLASH="run run_bootcore;ubi read ${loadaddr} ${kernel_vol};run flashargs addmisc;bootm ${loadaddr};reset"
CONFIG_UBOOT_CONFIG_UPDATE_NANDBOOT="if tftp ${loadaddr} ${tftppath}u-boot-nand.bin; then nand erase 0 180000;nand erase 1340000 6c00000;nand write.partial ${loadaddr} 0 ${filesize}; else echo Image not Found !!;fi"
CONFIG_UBOOT_CONFIG_UPDATE_UBOOT="if tftp ${loadaddr} ${tftppath}${u-boot};then nand write.partial ${loadaddr} 0x4000 ${filesize};else echo Image not Found !!;fi;reset"
CONFIG_UBOOT_CONFIG_UPDATE_BOOTLOADER="run update_uboot;run update_gphyfirmware;"
CONFIG_UBOOT_CONFIG_UPDATE_KERNEL="run ubi_init;if tftpboot ${loadaddr} ${tftppath}${bootfile}; then run switchbankB;upgrade ${loadaddr} ${filesize};run switchbankA;set update_chk 0;upgrade ${loadaddr} ${filesize}; else echo Image not found!!;fi"
CONFIG_UBOOT_CONFIG_UPDATE_ROOTFS="run ubi_init;if tftpboot ${loadaddr} ${tftppath}${rootfs};then run switchbankB;upgrade ${loadaddr} ${filesize};run switchbankA;set update_chk 0;upgrade ${loadaddr} ${filesize}; else echo Image not found !!;fi"
CONFIG_UBOOT_CONFIG_UPDATE_GPHYFIRMWARE="if tftpboot ${loadaddr} ${tftppath}gphy_firmware.img;then nand write.partial ${loadaddr} 0x180000 ${filesize}; else echo Image not Found !!;fi;re"
CONFIG_UBOOT_CONFIG_UPDATE_FULLIMAGE="run ubi_init;if tftpboot ${loadaddr} ${tftppath}${fullimage};then run switchbankB;upgrade ${loadaddr} ${filesize};run switchbankA;set update_chk 0;upgrade ${loadaddr} ${filesize}; ubi create rootfs_data 0x2000000; else echo Image not Found !!;fi"
CONFIG_UBOOT_CONFIG_UPDATE_TOTALIMAGE="run ubi_init;if tftpboot ${loadaddr} ${tftppath}${totalimage};then upgrade ${loadaddr} ${filesize}; else echo Image not Found !!;fi"
CONFIG_UBOOT_CONFIG_UPDATE_BOOTCORE="run ubi_init;if tftpboot ${loadaddr} ${tftppath}${bootcore};then run switchbankB;upgrade ${loadaddr} ${filesize};run switchbankA;set update_chk 0;upgrade ${loadaddr} ${filesize}; else echo Image not Found !!;fi"
CONFIG_UBOOT_CONFIG_RUN_BOOTCORE="run ubi_init; ubi read 0xA0400000 ${bootcore_vol} ; secboot load_os 0x88000000 0xA0400000 0x400000"
CONFIG_UBOOT_CONFIG_UBI_INIT="setenv kernelA_id 0;setenv rootfsA_id 1;setenv firmwareA_id 2;setenv kernelB_id 3;setenv rootfsB_id 4;setenv firmwareB_id 5;setenv bootcoreA_id 6; setenv bootcoreB_id 7;setenv setbank check_image${update_chk};run ${setbank};ubi part system_sw"
CONFIG_UBOOT_CONFIG_DUAL_IMAGE=y
CONFIG_UBOOT_CONFIG_UPDATE_CHK="0"
CONFIG_UBOOT_CONFIG_SWITCH_BANKA="setenv active_bank A;setenv kernel_id ${kernelA_id};setenv rootfs_id ${rootfsA_id};setenv f_kernel_size f_kernel_sizeA;setenv kernel_vol kernelA;setenv rootfs_vol rootfsA;setenv firmware_vol firmwareA;setenv rootfsname rootfsA;setenv bootcore_vol bootcoreA"
CONFIG_UBOOT_CONFIG_SWITCH_BANKB="setenv active_bank B;setenv kernel_id ${kernelB_id};setenv rootfs_id ${rootfsB_id};setenv f_kernel_size f_kernel_sizeB;setenv kernel_vol kernelB;setenv rootfs_vol rootfsB;setenv firmware_vol firmwareB;setenv rootfsname rootfsB;setenv bootcore_vol bootcoreB"
CONFIG_UBOOT_CONFIG_CHECK_IMAGE0="run switchbankA"
CONFIG_UBOOT_CONFIG_CHECK_IMAGE1="run switchbankB;setenv update_chk 0;save"
CONFIG_UBOOT_CONFIG_CHECK_IMAGE2="run switchbankB"
CONFIG_UBOOT_CONFIG_CHECK_IMAGE3="run switchbankA;setenv update_chk 2;save"
CONFIG_UBOOT_CONFIG_BOOTCOMMAND="run flash_flash"
CONFIG_UBOOT_CONFIG_RESET_UBOOT_CONFIG="nand erase ${f_ubootconfig_addr} ${f_ubootconfig_range};nand erase ${f_red_ubootconfig_addr} ${f_ubootconfig_range};"
CONFIG_UBOOT_CONFIG_RESET_DDR_CONFIG="nand write.partial 80400000 ${f_ddrconfig_addr} ${f_ddrconfig_size}"
CONFIG_UBOOT_CONFIG_RESET_SYSCONFIG="run ubi_init;ubi remove sysconfig;ubi remove sysconfigA;ubi remove sysconfigB"
CONFIG_UBOOT_CONFIG_BOARD_NAME="K3C"
CONFIG_UBOOT_CONFIG_EXTRA_ENV_DATA=""

#
# Network Settings
#
CONFIG_UBOOT_CONFIG_IP_ADDRESS="192.168.1.1"
CONFIG_UBOOT_CONFIG_SERVER_IP_ADDRESS="192.168.1.2"
CONFIG_UBOOT_CONFIG_ETHERNET_ADDRESS="00:E0:92:00:01:40"
CONFIG_UBOOT_CONFIG_ETHERNET_DEVICE="eth0"
CONFIG_UBOOT_CONFIG_SYS_BIG_ENDIAN=y
CONFIG_UBOOT_CONFIG_CPU_MIPS_IAP=y

