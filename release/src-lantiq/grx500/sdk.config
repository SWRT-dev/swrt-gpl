CONFIG_UBOOT_CONFIG_ENV_IS_IN_NAND=y
CONFIG_UBOOT_CONFIG_NAND_U_BOOT=y
CONFIG_UBOOT_CONFIG_RAM_TEXT_BASE=0xA0400000
CONFIG_UBOOT_CONFIG_BOOTSTRAP_TEXT_BASE=0x80200000
CONFIG_UBOOT_CONFIG_NAND_PRELOAD_TEXT_BASE=0xa0010000
CONFIG_UBOOT_CONFIG_NAND_SPL_TEXT_BASE=0xa0001000
